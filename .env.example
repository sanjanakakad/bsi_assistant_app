# Copy to .env for local development:  cp .env.example .env
# On Streamlit Cloud, add these in App settings → Secrets instead.

OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_ASSISTANT_ID=asst_your-assistant-id

# Optional — only needed when running populate_threat_store.py locally
OPENAI_VECTOR_STORE_ID=vs_your-vector-store-id
